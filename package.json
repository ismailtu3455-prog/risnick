{
  "name": "gatebox-platform",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "description": "Production-ready Telegram sponsor subscription platform",
  "engines": {
    "node": ">=18.20.0"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/main.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@fastify/multipart": "^7.7.3",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^1.10.2",
    "@prisma/client": "^6.8.2",
    "dotenv": "^16.5.0",
    "fastify": "^4.29.0",
    "ioredis": "^5.6.1",
    "prisma": "^6.8.2",
    "pino": "^9.7.0",
    "telegraf": "^4.16.3",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^1.6.1"
  }
}
